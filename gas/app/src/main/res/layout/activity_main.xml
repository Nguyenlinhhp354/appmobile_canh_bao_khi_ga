<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="20dp"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="HỆ THỐNG BÁO CHÁY IOT"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_phong1_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:background="#333333"
        android:gravity="center"
        android:padding="15dp"
        android:text="Phòng 1: Đang tải..."
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@+id/tv_title" />

    <TextView
        android:id="@+id/tv_phong2_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="#333333"
        android:gravity="center"
        android:padding="15dp"
        android:text="Phòng 2: Đang tải..."
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@+id/tv_phong1_status" />

    <LinearLayout
        android:id="@+id/layout_setup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@+id/tv_phong2_status">

        <EditText
            android:id="@+id/edt_ppm_limit"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Nhập giới hạn PPM (vd: 500)"
            android:inputType="number"
            android:textColor="#FFFFFF"
            android:textColorHint="#AAAAAA"
            android:backgroundTint="#FFFFFF"/>

        <Button
            android:id="@+id/btn_save_ppm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lưu Cài Đặt"
            android:backgroundTint="#FF9800"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tv_current_limit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ngưỡng hiện tại: ..."
        android:textColor="#FFFF00"
        android:gravity="center"
        android:layout_marginTop="5dp"
        app:layout_constraintTop_toBottomOf="@+id/layout_setup"/>

    <LinearLayout
        android:id="@+id/layout_mute_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@+id/tv_current_limit">

        <Button
            android:id="@+id/btn_mute_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            android:backgroundTint="#D32F2F"
            android:text="🔕 Tắt Còi P1" />

        <Button
            android:id="@+id/btn_mute_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="5dp"
            android:backgroundTint="#D32F2F"
            android:text="🔕 Tắt Còi P2" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_history"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:backgroundTint="#1976D2"
        android:padding="15dp"
        android:text="📋 XEM LỊCH SỬ CHI TIẾT"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@+id/layout_mute_buttons" />



</androidx.constraintlayout.widget.ConstraintLayout>